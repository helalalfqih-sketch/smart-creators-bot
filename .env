TELEGRAM_BOT_TOKEN=8623301211:AAFZ77fMxpWXT3qK5Wy28eTtD5xlGFC99ik

# ── FastAPI server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DOWNLOAD_API_URL=http://127.0.0.1:8000

# ── yt-dlp ────────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
MAX_FILESIZE_MB=50
MAX_CONCURRENT_DOWNLOADS=3

# ── Redis (اختياري) ────────────────────────────────────────────────────────────
# إذا لم يكن Redis متاحاً، يتم الرجوع تلقائياً لـ memory cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Misc ──────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=300
LOG_LEVEL=INFO
